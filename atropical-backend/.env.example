# Copia este ficheiro para ".env" (uso local) ou configura estas mesmas
# variáveis no painel da Vercel (Settings → Environment Variables).
# NUNCA preenchas valores reais diretamente neste ficheiro .env.example,
# nem o envies para um repositório público.

# --- Anthropic (IA: Guia, classificação de vouchers, leitura do programa) ---
ANTHROPIC_API_KEY=

# --- Optitravel ---
OPTITRAVEL_API_BASE_URL=https://api-rest.optitravel.net
OPTITRAVEL_API_TOKEN=
